<%- include('../partials/head', { title: 'Test Series' }) %>
<body class="min-h-screen bg-gray-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen p-6 max-w-7xl mx-auto">

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-bold text-gray-800">Test Series</h1>
      <button onclick="toggleCreate()"
              class="flex items-center gap-2 px-4 py-2 bg-transparent border border-garud-highlight text-garud-highlight rounded-lg hover:bg-gray-100 transition">
        + Create Series
      </button>
    </div>

    <!-- Create form -->
    <div id="create-form-wrap" class="hidden bg-white rounded-xl shadow-md p-6 mb-6">
      <h2 class="text-lg font-bold text-gray-800 mb-4">New Test Series</h2>
      <form id="create-series-form" class="space-y-5">

        <!-- Name -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Series Name <span class="text-red-500">*</span></label>
          <input id="series-name" type="text" required placeholder="e.g., NEET 2026 Full Test Series"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"/>
        </div>

        <!-- Banner -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Banner Photo <span class="text-gray-400 font-normal">(optional)</span></label>
          <div id="banner-drop-zone"
               class="border-2 border-dashed border-gray-300 rounded-xl p-6 flex flex-col items-center justify-center gap-2 cursor-pointer hover:border-garud-accent transition"
               onclick="document.getElementById('banner-file').click()">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p id="banner-label" class="text-sm text-gray-500">Click to upload banner image</p>
          </div>
          <input id="banner-file" type="file" accept="image/*" class="hidden" onchange="previewBanner(this)"/>
          <img id="banner-preview" src="" alt="" class="hidden mt-3 rounded-lg max-h-40 object-cover w-full"/>
        </div>

        <!-- Price -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Price (Ã¢â€šÂ¹)</label>
          <input id="series-price" type="number" min="0" value="0"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"/>
        </div>

        <!-- Categories / Tags -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Target Categories <span class="text-gray-400 font-normal">(select all that apply)</span></label>
          <div class="flex flex-wrap gap-2" id="category-chips">
            <%
              const cats = ['JEE','NEET','CUET UG','FOUNDATION','NDA','Class 9','Class 10','Class 11','Class 12','Dropper'];
              cats.forEach(cat => {
            %>
              <label class="cursor-pointer">
                <input type="checkbox" name="tags" value="<%= cat %>" class="hidden category-cb"/>
                <span class="chip px-3 py-1.5 rounded-full border text-sm font-medium transition select-none
                             border-gray-300 bg-gray-50 text-gray-600 hover:border-garud-accent"
                      data-cat="<%= cat %>"><%= cat %></span>
              </label>
            <% }); %>
          </div>
        </div>

        <!-- Description (pointwise) -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Description <span class="text-gray-400 font-normal">(point-wise)</span></label>
          <div id="desc-points" class="space-y-2 mb-2"></div>
          <button type="button" onclick="addDescPoint()"
                  class="flex items-center gap-1 text-sm text-garud-accent hover:text-garud-highlight font-medium transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Add Point
          </button>
        </div>

        <!-- Actions -->
        <div class="flex gap-3 pt-2">
          <button type="submit" id="create-submit-btn"
                  class="flex items-center gap-2 px-6 py-2 bg-garud-highlight text-white rounded-lg font-medium hover:opacity-90 transition">
            <span id="create-spinner" class="hidden w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
            Create Series
          </button>
          <button type="button" onclick="toggleCreate()"
                  class="px-6 py-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition">
            Cancel
          </button>
        </div>
      </form>
    </div>

    <div id="loading" class="flex items-center justify-center py-12"><div class="spinner"></div></div>
    <div id="series-list" class="hidden space-y-4"></div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/admin-test-series-list.js"></script>
</body>
</html>
