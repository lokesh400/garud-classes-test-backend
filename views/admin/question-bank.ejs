<%- include('../partials/head', { title: 'Question Bank' }) %>
<body class="min-h-screen bg-gray-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen p-6 max-w-7xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-800 mb-6">Question Bank Manager</h1>

    <!-- Add Forms -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">

      <!-- Add Subject -->
      <form id="add-subject-form" class="bg-white rounded-xl shadow-md p-4">
        <h3 class="font-semibold text-gray-700 mb-3 flex items-center gap-2">
          <span class="text-blue-500">Ã°Å¸â€œÅ¡</span> Add Subject
        </h3>
        <div class="flex gap-2">
          <input id="new-subject" type="text" placeholder="Subject name"
                 class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400 outline-none"/>
          <button type="submit"
                  class="px-3 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition">+</button>
        </div>
      </form>

      <!-- Add Chapter -->
      <form id="add-chapter-form" class="bg-white rounded-xl shadow-md p-4">
        <h3 class="font-semibold text-gray-700 mb-3 flex items-center gap-2">
          <span class="text-green-500">Ã°Å¸â€œâ€˜</span> Add Chapter
        </h3>
        <select id="chapter-subject-select"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm mb-2 focus:ring-2 focus:ring-green-400 outline-none">
          <option value="">Select Subject</option>
        </select>
        <div class="flex gap-2">
          <input id="new-chapter" type="text" placeholder="Chapter name"
                 class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-green-400 outline-none"/>
          <button type="submit"
                  class="px-3 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition">+</button>
        </div>
      </form>

      <!-- Add Topic -->
      <form id="add-topic-form" class="bg-white rounded-xl shadow-md p-4">
        <h3 class="font-semibold text-gray-700 mb-3 flex items-center gap-2">
          <span class="text-purple-500">Ã°Å¸ÂÂ·</span> Add Topic
        </h3>
        <select id="topic-chapter-select"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm mb-2 focus:ring-2 focus:ring-purple-400 outline-none">
          <option value="">Select Chapter</option>
        </select>
        <div class="flex gap-2">
          <input id="new-topic" type="text" placeholder="Topic name"
                 class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-purple-400 outline-none"/>
          <button type="submit"
                  class="px-3 py-2 bg-purple-500 text-white rounded-lg hover:bg-purple-600 transition">+</button>
        </div>
      </form>
    </div>

    <!-- Three-column browser -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Subjects -->
      <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-blue-50 px-4 py-3 border-b flex items-center gap-2">
          <span class="text-blue-500 font-semibold text-sm">Ã°Å¸â€œÅ¡ Subjects</span>
        </div>
        <div id="subjects-list" class="divide-y divide-gray-100 max-h-96 overflow-y-auto"></div>
      </div>

      <!-- Chapters -->
      <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-green-50 px-4 py-3 border-b">
          <span class="text-green-600 font-semibold text-sm">Ã°Å¸â€œâ€˜ Chapters</span>
          <span id="chapters-title" class="text-xs text-gray-400 ml-2"></span>
        </div>
        <div id="chapters-list" class="divide-y divide-gray-100 max-h-96 overflow-y-auto"></div>
      </div>

      <!-- Topics -->
      <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-purple-50 px-4 py-3 border-b">
          <span class="text-purple-600 font-semibold text-sm">Ã°Å¸ÂÂ· Topics</span>
          <span id="topics-title" class="text-xs text-gray-400 ml-2"></span>
        </div>
        <div id="topics-list" class="divide-y divide-gray-100 max-h-96 overflow-y-auto"></div>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/question-bank.js"></script>
</body>
</html>
