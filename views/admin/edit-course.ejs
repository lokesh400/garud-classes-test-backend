<%- include('../partials/head', { title: 'Edit Course' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Admin Panel</p>
      <h1 id="page-title" class="text-2xl md:text-3xl font-bold text-white">Edit Course</h1>
      <p class="text-white/60 text-sm mt-1">Manage complete course data from one dedicated page.</p>
    </div>

    <div class="p-6 md:p-8 space-y-6">
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 md:p-5 lift fade-up-1">
        <div class="flex flex-wrap items-center gap-2">
          <a href="/admin/courses/create/new" class="px-3 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50">Back to Courses</a>
          <button id="delete-course-btn" type="button" class="px-3 py-2 rounded-lg border border-red-200 text-sm text-red-600 hover:bg-red-50">Delete Course</button>
        </div>
      </section>

      <section id="loading-state" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-sm text-gray-500">Loading course...</section>

      <section id="error-state" class="hidden bg-white rounded-2xl shadow-sm border border-red-100 p-6 text-sm text-red-600"></section>

      <section id="editor-state" class="hidden space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
            <p class="text-xs uppercase tracking-wide text-gray-500">Lectures</p>
            <p id="meta-lectures" class="text-2xl font-bold text-gray-900 mt-1">0</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
            <p class="text-xs uppercase tracking-wide text-gray-500">Purchases</p>
            <p id="meta-purchases" class="text-2xl font-bold text-gray-900 mt-1">0</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
            <p class="text-xs uppercase tracking-wide text-gray-500">Created By</p>
            <p id="meta-created-by" class="text-sm font-semibold text-gray-900 mt-2">-</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
            <p class="text-xs uppercase tracking-wide text-gray-500">Updated</p>
            <p id="meta-updated-at" class="text-sm font-semibold text-gray-900 mt-2">-</p>
          </div>
        </div>

        <form id="edit-course-form" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 md:p-6 space-y-5">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="course-name" class="block text-sm font-medium text-gray-700 mb-1">Course Name</label>
              <input id="course-name" type="text" maxlength="80" required class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm" />
            </div>
            <div>
              <label for="course-price" class="block text-sm font-medium text-gray-700 mb-1">Price (INR)</label>
              <input id="course-price" type="number" min="0" step="1" class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm" />
            </div>
          </div>

          <div>
            <label for="course-description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <textarea id="course-description" rows="3" maxlength="300" class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm resize-none"></textarea>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label for="course-made-for" class="block text-sm font-medium text-gray-700 mb-1">Category</label>
              <select id="course-made-for" class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm">
                <option value="other">Other</option>
                <option value="jee">JEE</option>
                <option value="neet">NEET</option>
              </select>
            </div>
            <div>
              <label for="course-image" class="block text-sm font-medium text-gray-700 mb-1">Image URL</label>
              <input id="course-image" type="url" placeholder="https://..." class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm" />
            </div>
            <div>
              <label for="course-tags" class="block text-sm font-medium text-gray-700 mb-1">Tags</label>
              <input id="course-tags" type="text" placeholder="foundation, revision" class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm" />
            </div>
          </div>

          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input id="course-published" type="checkbox" class="rounded border-gray-300" />
            Publish course
          </label>

          <div class="border border-gray-200 rounded-xl p-3 bg-slate-50 space-y-3">
            <div class="flex items-center justify-between">
              <h3 class="text-sm font-semibold text-gray-700">Lectures, Video Links and PDFs</h3>
              <button id="add-lecture-row" type="button" class="px-2.5 py-1.5 rounded-lg text-xs font-semibold bg-garud-accent text-white">+ Add Lecture</button>
            </div>
            <div id="lecture-rows" class="space-y-3"></div>
            <p class="text-xs text-gray-500">Lecture title is required. Video links and PDFs are optional. For each PDF, provide title and Zenodo link.</p>
          </div>

          <div class="pt-1 flex items-center justify-end gap-3">
            <a href="/admin/courses/create/new" class="px-4 py-2.5 rounded-xl border border-gray-300 text-gray-700 font-medium hover:bg-gray-50">Cancel</a>
            <button id="save-course-btn" type="submit" class="px-4 py-2.5 rounded-xl bg-garud-highlight text-white font-semibold hover:opacity-95">Update Course</button>
          </div>
        </form>
      </section>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/admin/course-edit.js"></script>
</body>
</html>
