<%- include('../partials/head', { title: 'Test Creator' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen p-6 md:p-8">

    <!-- Loading -->
    <div id="loading" class="flex items-center justify-center min-h-[60vh]"><div class="spinner"></div></div>

    <!-- Main content -->
    <div id="main-content" class="hidden">

      <!-- Header -->
      <div class="flex items-center gap-4 mb-6">
        <button onclick="history.back()"
                class="p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition">&larr;</button>
        <div>
          <h1 id="test-title" class="text-2xl font-bold text-gray-800"></h1>
          <p id="test-meta"  class="text-sm text-gray-500"></p>
        </div>
      </div>

      <!-- Marks config row -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-4 mb-4 flex flex-wrap gap-4 items-center">
        <label class="text-sm font-medium text-gray-700">
          +Marks per question:
          <input id="positive-marks" type="number" min="0" step="0.5" value="4"
                 class="ml-2 w-16 px-2 py-1 border border-gray-300 rounded text-sm outline-none focus:ring-2 focus:ring-garud-accent"/>
        </label>
        <label class="text-sm font-medium text-gray-700">
          &minus;Marks per wrong:
          <input id="negative-marks" type="number" min="0" step="0.5" value="1"
                 class="ml-2 w-16 px-2 py-1 border border-gray-300 rounded text-sm outline-none focus:ring-2 focus:ring-garud-accent"/>
        </label>
      </div>

      <!-- Add Section -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-4 mb-6">
        <div class="flex gap-2 items-center">
          <input id="new-section-name" type="text" placeholder="New section name (e.g., Physics, Chemistry)"
                 class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-garud-accent outline-none"/>
          <button onclick="addSection()"
                  class="px-4 py-2 bg-garud-highlight text-white rounded-lg text-sm font-medium hover:opacity-90 transition">
            Add Section
          </button>
        </div>
      </div>

      <!-- Sections -->
      <div id="sections-container"></div>
      </div><!-- /p-6 -->

      <!-- Question Picker Modal -->
      <div id="picker-modal"
           class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center hidden p-4">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-4xl max-h-[85vh] flex flex-col">
          <div class="flex items-center justify-between px-6 py-4 border-b">
            <h3 class="font-bold text-gray-800">Add Questions to Section</h3>
            <button onclick="closePicker()" class="text-gray-400 hover:text-gray-600 text-xl">&#x2715;</button>
          </div>

          <!-- Filters -->
          <div class="px-6 py-3 border-b flex flex-wrap gap-3">
            <select id="f-subject"
                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-garud-accent">
              <option value="">All Subjects</option>
            </select>
            <select id="f-chapter"
                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-garud-accent">
              <option value="">All Chapters</option>
            </select>
            <select id="f-topic"
                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-garud-accent">
              <option value="">All Topics</option>
            </select>
          </div>

          <!-- Question grid -->
          <div id="question-grid" class="flex-1 overflow-y-auto p-6 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"></div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/test-creator.js"></script>
</body>
</html>
