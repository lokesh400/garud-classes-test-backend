<%- include('../partials/head', { title: 'Test Creator' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen p-6 md:p-8 mt-6">

    <!-- Loading -->
    <div id="loading" class="flex items-center justify-center min-h-[60vh]"><div class="spinner"></div></div>

    <!-- Main content -->
    <div id="main-content" class="hidden">

      <!-- Header -->
      <div class="flex items-center gap-4 mb-6">
        <button onclick="history.back()"
                class="p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition">&larr;</button>
        <div>
          <h1 id="test-title" class="text-2xl font-bold text-gray-800"></h1>
          <p id="test-meta"  class="text-sm text-gray-500"></p>
        </div>
      </div>

      <!-- Marks config row -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-4 mb-4 flex flex-wrap gap-4 items-center">
        <label class="text-sm font-medium text-gray-700">
          +Marks per question:
          <input id="positive-marks" type="number" min="0" step="0.5" value="4"
                 class="ml-2 w-16 px-2 py-1 border border-gray-300 rounded text-sm outline-none focus:ring-2 focus:ring-garud-accent"/>
        </label>
        <label class="text-sm font-medium text-gray-700">
          &minus;Marks per wrong:
          <input id="negative-marks" type="number" min="0" step="0.5" value="1"
                 class="ml-2 w-16 px-2 py-1 border border-gray-300 rounded text-sm outline-none focus:ring-2 focus:ring-garud-accent"/>
        </label>
      </div>

      <!-- Test Settings (schedule + mode) -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-4 mb-4">
        <button type="button" onclick="toggleSettings()"
                class="flex items-center gap-2 text-sm font-semibold text-gray-700 hover:text-gray-900 w-full text-left">
          <span id="settings-arrow" class="transition-transform">▶</span> Test Settings (schedule &amp; mode)
        </button>
        <div id="settings-panel" class="hidden mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Scheduled Date &amp; Time
              <span class="text-gray-400 font-normal">(leave blank = available immediately)</span>
            </label>
            <input id="setting-scheduled-at" type="datetime-local"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none text-sm"/>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Mode</label>
            <select id="setting-mode"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none text-sm">
              <option value="real">🎯 Real — student can submit only once</option>
              <option value="practice">🔁 Practice — unlimited attempts</option>
            </select>
          </div>
          <div class="md:col-span-2 flex gap-3">
            <button type="button" onclick="saveSettings()"
                    class="px-5 py-2 bg-garud-highlight text-white rounded-lg text-sm font-medium hover:opacity-90 transition">
              Save Settings
            </button>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Syllabus
              <span class="text-gray-400 font-normal">(topics covered — shown to students on the start screen)</span>
            </label>
            <textarea id="setting-syllabus" rows="5"
                      placeholder="e.g. Chapter 1: Laws of Motion&#10;Chapter 2: Work &amp; Energy&#10;Chapter 3: Gravitation"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none text-sm font-mono"></textarea>
          </div>
        </div>
      </div>

      <!-- Add Section -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-4 mb-6">
        <div class="flex gap-2 items-center">
          <input id="new-section-name" type="text" placeholder="New section name (e.g., Physics, Chemistry)"
                 class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-garud-accent outline-none"/>
          <button onclick="addSection()"
                  class="px-4 py-2 bg-garud-highlight text-white rounded-lg text-sm font-medium hover:opacity-90 transition">
            Add Section
          </button>
        </div>
      </div>

      <!-- Sections -->
      <div id="sections-container"></div>

    </div><!-- /#main-content -->
  </div><!-- /.md:ml-60 -->

  <!-- Question Picker Modal — body-level fixed overlay -->
  <div id="picker-modal"
       class="fixed inset-0 z-50 hidden">
    <div class="bg-white w-full h-full flex flex-col">

      <!-- Modal header -->
      <div class="flex items-center justify-between px-6 py-4 border-b flex-shrink-0">
        <h3 class="font-bold text-gray-800">Add Questions to Section</h3>
        <button onclick="closePicker()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>

      <!-- Filters -->
      <div class="px-6 py-3 border-b flex flex-wrap gap-3 flex-shrink-0">
        <select id="f-subject"
                class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-garud-accent">
          <option value="">All Subjects</option>
        </select>
        <select id="f-chapter"
                class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-garud-accent">
          <option value="">All Chapters</option>
        </select>
        <select id="f-topic"
                class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-garud-accent">
          <option value="">All Topics</option>
        </select>
        <select id="f-type"
                class="px-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-garud-accent">
          <option value="">All Types</option>
          <option value="mcq">MCQ</option>
          <option value="msq">MSQ</option>
          <option value="numerical">Numerical</option>
        </select>
      </div>

      <!-- Loading state -->
      <div id="picker-loading" class="hidden items-center justify-center py-12 flex-shrink-0">
        <div class="spinner"></div>
      </div>

      <!-- Question grid — takes all remaining height and scrolls -->
      <div id="question-grid"
           class="overflow-y-auto p-6 grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-5"
           style="flex:1 1 0%; min-height:0;"></div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/test-creator.js"></script>
</body>
</html>
