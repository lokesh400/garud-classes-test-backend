<%- include('../partials/head', { title: 'Admin Dashboard' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen">
    <div id="loading" class="flex items-center justify-center min-h-[60vh]">
      <div class="spinner"></div>
    </div>

    <div id="main-content" class="hidden page-body">
      <!-- Page Header -->
      <div class="page-header px-6 md:px-8 py-7 fade-up">
        <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Admin Panel</p>
        <h1 class="text-2xl md:text-3xl font-bold text-white">Dashboard</h1>
        <p class="text-white/60 text-sm mt-1">Platform overview &amp; quick access</p>
      </div>

      <div class="p-6 md:p-8">
        <!-- Stat cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8" id="stat-cards"></div>

        <!-- Quick guide -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-6 md:p-8 fade-up-1">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-9 h-9 rounded-xl bg-garud-accent/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-garud-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h2 class="text-lg font-bold text-gray-800">Quick Guide</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex gap-3 p-4 rounded-xl bg-blue-50 border border-blue-100">
              <span class="w-7 h-7 rounded-full bg-blue-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">1</span>
              <p class="text-sm text-gray-700">Go to <span class="font-semibold text-garud-accent">Question Bank</span> to manage Subjects &rarr; Chapters &rarr; Topics</p>
            </div>
            <div class="flex gap-3 p-4 rounded-xl bg-emerald-50 border border-emerald-100">
              <span class="w-7 h-7 rounded-full bg-emerald-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">2</span>
              <p class="text-sm text-gray-700">Use <span class="font-semibold text-emerald-700">Upload</span> page to upload question images to Cloudinary</p>
            </div>
            <div class="flex gap-3 p-4 rounded-xl bg-violet-50 border border-violet-100">
              <span class="w-7 h-7 rounded-full bg-violet-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">3</span>
              <p class="text-sm text-gray-700">Create tests in the <span class="font-semibold text-violet-700">Tests</span> section with sections and assign questions</p>
            </div>
            <div class="flex gap-3 p-4 rounded-xl bg-amber-50 border border-amber-100">
              <span class="w-7 h-7 rounded-full bg-amber-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">4</span>
              <p class="text-sm text-gray-700">Publish tests to make them <span class="font-semibold text-amber-700">visible to students</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/admin-dashboard.js"></script>
</body>
</html>
