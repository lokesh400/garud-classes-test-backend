<%- include('../partials/head', { title: 'Tests' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

<div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Admin Panel</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white">Tests</h1>
      <p class="text-white/60 text-sm mt-1">Create and manage tests for students</p>
    </div>

    <div class="p-6 md:p-8">
    <div class="flex items-center justify-between mb-6">
      <p class="text-gray-500 text-sm">All available tests</p>
      <button onclick="toggleCreate()"
              class="flex items-center gap-2 px-4 py-2 bg-garud-highlight text-white rounded-xl font-medium hover:opacity-90 transition shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Create Test
      </button>
    </div>

    <!-- Create Form -->
    <div id="create-form-wrap" class="hidden bg-white rounded-2xl shadow-sm border border-gray-100 lift p-6 mb-6">
      <h2 class="text-lg font-bold text-gray-800 mb-4">New Test</h2>
      <form id="create-test-form" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Test Name</label>
            <input id="test-name" type="text" required placeholder="e.g., Physics Weekly Test 1"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"/>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Duration (minutes)</label>
            <input id="test-duration" type="number" min="1" value="180" required
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"/>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Scheduled Date &amp; Time <span class="text-gray-400 font-normal">(optional — students can't start before this)</span></label>
            <input id="test-scheduled-at" type="datetime-local"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"/>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Mode</label>
            <select id="test-mode"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none">
              <option value="real">Real — student can submit only once</option>
              <option value="practice">Practice — unlimited attempts</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description (optional)</label>
          <textarea id="test-desc" rows="2" placeholder="Optional description…"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Syllabus <span class="text-gray-400 font-normal">(optional — topics covered, shown to students before the test)</span></label>
          <textarea id="test-syllabus" rows="3" placeholder="e.g. Chapter 1: Motion, Chapter 2: Laws of Motion, Chapter 5: Work &amp; Energy…"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"></textarea>
        </div>
        <div class="flex gap-3">
          <button type="submit"
                  class="px-6 py-2 bg-garud-highlight text-white rounded-lg font-medium hover:opacity-90 transition">
            Create Test
          </button>
          <button type="button" onclick="toggleCreate()"
                  class="px-6 py-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition">
            Cancel
          </button>
        </div>
      </form>
    </div>

    <!-- Tests list -->
    <div id="loading" class="flex items-center justify-center py-16"><div class="spinner"></div></div>
    <div id="tests-list" class="hidden space-y-4"></div>
    </div><!-- /inner -->
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/test-list.js"></script>
</body>
</html>
