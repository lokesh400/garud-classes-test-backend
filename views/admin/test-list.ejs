<%- include('../partials/head', { title: 'Tests' }) %>
<body class="min-h-screen bg-gray-50 text-gray-900">
  <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen p-6 max-w-7xl mx-auto">

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-bold text-gray-800">Tests</h1>
      <button onclick="toggleCreate()"
              class="flex items-center gap-2 px-4 py-2 bg-transparent border border-garud-highlight text-garud-highlight rounded-lg hover:bg-gray-100 transition">
        + Create Test
      </button>
    </div>

    <!-- Create Form -->
    <div id="create-form-wrap" class="hidden bg-white rounded-xl shadow-md p-6 mb-6">
      <h2 class="text-lg font-bold text-gray-800 mb-4">New Test</h2>
      <form id="create-test-form" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Test Name</label>
            <input id="test-name" type="text" required placeholder="e.g., Physics Weekly Test 1"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"/>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Duration (minutes)</label>
            <input id="test-duration" type="number" min="1" value="180" required
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"/>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description (optional)</label>
          <textarea id="test-desc" rows="2" placeholder="Optional descriptionâ€¦"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent outline-none"></textarea>
        </div>
        <div class="flex gap-3">
          <button type="submit"
                  class="px-6 py-2 bg-garud-highlight text-white rounded-lg font-medium hover:opacity-90 transition">
            Create Test
          </button>
          <button type="button" onclick="toggleCreate()"
                  class="px-6 py-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition">
            Cancel
          </button>
        </div>
      </form>
    </div>

    <!-- Tests list -->
    <div id="loading" class="flex items-center justify-center py-12"><div class="spinner"></div></div>
    <div id="tests-list" class="hidden space-y-4"></div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/test-list.js"></script>
</body>
</html>
