<%- include('../partials/head', { title: 'Upload Questions' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Admin Panel</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white">Upload Questions</h1>
      <p class="text-white/60 text-sm mt-1">Upload question images to the question bank</p>
    </div>

    <div class="p-6 md:p-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Upload Form -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-6 fade-up">
        <form id="upload-form" class="space-y-4">

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
            <select id="sel-subject" required
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-garud-accent outline-none">
              <option value="">Select Subject</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Chapter</label>
            <select id="sel-chapter" required
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-garud-accent outline-none">
              <option value="">Select Chapter</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Topic</label>
            <select id="sel-topic" required
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-garud-accent outline-none">
              <option value="">Select Topic</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Question Type</label>
            <select id="sel-type"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-garud-accent outline-none">
              <option value="mcq">MCQ</option>
              <option value="numerical">Numerical</option>
            </select>
          </div>

          <!-- MCQ correct option -->
          <div id="mcq-options">
            <label class="block text-sm font-medium text-gray-700 mb-1">Correct Option</label>
            <select id="sel-correct-option"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-garud-accent outline-none">
              <option>A</option><option>B</option><option>C</option><option>D</option>
            </select>
          </div>

          <!-- Numerical answer -->
          <div id="numerical-options" class="hidden">
            <label class="block text-sm font-medium text-gray-700 mb-1">Correct Numerical Answer</label>
            <input id="inp-numerical" type="number" step="any"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-garud-accent outline-none"/>
          </div>

          <!-- Image upload -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Question Image</label>
            <label for="question-image"
                   class="flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-lg p-6 cursor-pointer hover:border-garud-accent transition">
              <span class="text-3xl mb-2">&#x1F5BC;</span>
              <span class="text-sm text-gray-500">Click or drag to upload</span>
              <input id="question-image" type="file" accept="image/*" class="hidden"/>
            </label>
            <img id="image-preview" class="mt-3 max-h-48 rounded border hidden" alt="Preview"/>
          </div>

          <button type="submit" id="upload-btn"
                  class="w-full py-2.5 bg-garud-highlight text-white font-semibold rounded-lg hover:opacity-90 transition disabled:opacity-50">
            Upload Question
          </button>
        </form>
      </div>

      <!-- Recently uploaded -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-6 fade-up-1">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Recently Uploaded</h2>
        <div id="recent-list" class="space-y-3 max-h-[500px] overflow-y-auto">
          <p class="text-sm text-gray-400">No uploads yet in this session.</p>
        </div>
      </div>
    </div>
    </div><!-- /inner -->
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/question-upload.js"></script>
</body>
</html>
