<%- include('./partials/head', { title: 'Account Deletion Policy' }) %>
<body class="min-h-screen bg-gradient-to-br from-garud-dark via-garud-mid to-garud-accent text-white page-body">
  <div class="absolute top-[-90px] left-[-80px] w-80 h-80 bg-garud-highlight/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-[-70px] right-[-80px] w-72 h-72 bg-garud-accent/20 rounded-full blur-3xl"></div>

  <main class="relative z-10 max-w-3xl mx-auto px-4 py-10 sm:py-14">
    <div class="text-center mb-8 fade-up">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-garud-highlight/20 border border-garud-highlight/30 mb-4">
        <span class="text-2xl font-black text-garud-highlight">G</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight">Account Deletion Policy</h1>
      <p class="text-white/60 text-sm mt-2">GARUD Classes</p>
    </div>

    <section class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl shadow-2xl p-6 sm:p-8 space-y-5 fade-up-1">
      <p class="text-white/85 leading-relaxed">
        You can request deletion of your GARUD Classes account at any time.
      </p>

      <div class="rounded-2xl border border-garud-highlight/30 bg-garud-highlight/10 p-4">
        <p class="text-sm sm:text-base font-semibold text-garud-highlight">Important Notice</p>
        <p class="text-white/90 mt-1 leading-relaxed">
          Account deletion can be requested, but payment records and financial transaction details will not be deleted.
        </p>
      </div>

      <p class="text-white/80 leading-relaxed">
        We retain billing and transaction information for legal, tax, audit, fraud-prevention, and compliance requirements.
      </p>

      <div class="pt-2">
        <h2 class="text-lg font-bold">How To Request Deletion</h2>
        <p class="text-white/80 mt-2 leading-relaxed">
          Send your deletion request from your registered email address to
          <a href="mailto:info@garudclasses.com" class="text-garud-highlight font-semibold hover:underline">info@garudclasses.com</a>
          or contact support at
          <a href="tel:9896913009" class="text-garud-highlight font-semibold hover:underline">9896913009</a>.
        </p>
      </div>

      <div class="pt-3 border-t border-white/10 flex flex-wrap gap-3">
        <a href="/login" class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl bg-garud-highlight text-white font-semibold hover:opacity-90 transition">Back To Login</a>
        <a href="/register" class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl border border-white/20 text-white/80 hover:bg-white/10 transition">Create Account</a>
      </div>
    </section>
  </main>
</body>
</html>
