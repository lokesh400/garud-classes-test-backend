<%- include('./partials/head', { title: 'Sign In' }) %>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-garud-dark to-garud-mid">

  <div class="max-w-md w-full mx-4">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-garud-highlight">GARUD</h1>
      <p class="text-gray-400 mt-1">Classes Test Portal</p>
    </div>

    <div class="bg-white rounded-xl shadow-2xl p-8">
      <h2 class="text-2xl font-bold text-gray-800 mb-6">Sign In</h2>

      <form id="login-form" class="space-y-4" novalidate>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input id="email" type="email" autocomplete="email"
                 class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent focus:border-transparent outline-none transition"
                 placeholder="Enter your email" required/>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input id="password" type="password" autocomplete="current-password"
                 class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-garud-accent focus:border-transparent outline-none transition"
                 placeholder="Enter your password" required/>
        </div>

        <button id="submit-btn" type="submit"
                class="w-full py-2.5 bg-transparent border border-garud-highlight text-garud-highlight font-semibold rounded-lg
                       hover:bg-gray-100 transition disabled:opacity-50">
          Sign In
        </button>
      </form>

      <p class="mt-4 text-center text-sm text-gray-600">
        Don't have an account?
        <a href="/register" class="text-garud-highlight font-semibold hover:underline">Register here</a>
      </p>
    </div>
  </div>

  <%- include('./partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/pages/login.js"></script>
</body>
</html>
