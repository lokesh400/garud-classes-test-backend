<%- include('../partials/head', { title: 'Test Series' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen p-6 md:p-8 mt-8">
    <div id="loading" class="flex items-center justify-center min-h-[60vh]"><div class="spinner"></div></div>
    <div id="main-content" class="hidden">

      <!-- Header -->
      <div class="flex items-center gap-4 mb-6">
        <button onclick="window.location.href='/student/purchase-series'"
                class="p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition">&larr;</button>
        <div>
          <h1 id="series-name" class="text-2xl font-bold text-gray-800"></h1>
          <p  id="series-desc"  class="text-sm text-gray-500 mt-1 hidden"></p>
          <div id="purchase-actions" class="mt-3"></div>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="p-6 md:p-8">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-5 mb-6 fade-up-1">
        <div class="flex items-center justify-between mb-3">
          <h3 class="font-semibold text-gray-700">Your Progress</h3>
          <span id="progress-text" class="text-sm text-gray-500"></span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div id="progress-bar" class="bg-garud-highlight h-2 rounded-full transition-all duration-500" style="width:0%"></div>
        </div>
      </div>

      <!-- Tests list -->
      <div id="tests-list" class="space-y-3"></div>
      </div><!-- /p-6 -->
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/test-series-view.js"></script>
</body>
</html>
