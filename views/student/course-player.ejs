<%- include('../partials/head', { title: 'Course Player' }) %>
<body class="min-h-screen bg-slate-950 text-white">
  <div id="loading" class="min-h-screen flex items-center justify-center"><div class="spinner"></div></div>

  <div id="player-root" class="hidden min-h-screen flex flex-col">
    <header class="px-4 md:px-6 py-3 border-b border-white/10 bg-slate-950/80 backdrop-blur-xl flex items-center justify-between gap-3 sticky top-0 z-30">
      <div class="min-w-0">
        <button id="back-btn" class="text-xs md:text-sm text-cyan-300 hover:text-cyan-200 mb-1">&larr; Back to Course</button>
        <h1 id="player-course-name" class="text-sm md:text-lg font-semibold truncate">Course</h1>
        <p id="player-lecture-title" class="text-xs text-white/60 truncate">Lecture</p>
      </div>
      <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-xl p-1">
        <button id="tab-video" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-red-500 text-white">Play Video</button>
        <button id="tab-attachments" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-white/10 text-white/80">Attachments</button>
      </div>
    </header>

    <main class="flex-1 grid grid-cols-1 xl:grid-cols-[1fr_370px] min-h-0 relative">
      <div class="absolute inset-0 pointer-events-none opacity-30">
        <div class="absolute -top-24 left-10 w-72 h-72 rounded-full bg-cyan-500/20 blur-3xl"></div>
        <div class="absolute bottom-0 right-10 w-72 h-72 rounded-full bg-orange-500/20 blur-3xl"></div>
      </div>

      <section class="min-h-[55vh] xl:min-h-0 p-3 md:p-5 relative">
        <div id="player-panel" class="h-full rounded-2xl border border-white/10 bg-black/70 backdrop-blur overflow-hidden shadow-2xl shadow-black/40"></div>
      </section>

      <aside class="border-t xl:border-t-0 xl:border-l border-white/10 bg-slate-950/65 backdrop-blur-xl p-3 md:p-4 overflow-y-auto relative">
        <p class="text-xs uppercase tracking-[0.18em] text-white/50 mb-2">Lecture Roadmap</p>
        <div id="player-lecture-list" class="space-y-2"></div>
      </aside>
    </main>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/pages/student/course-player.js"></script>
</body>
</html>
