<%- include('../partials/head', { title: 'Battleground' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Student Portal</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white">Daily Battleground</h1>
      <p class="text-white/60 text-sm mt-1">Solve today's class-wise subject quizzes and keep your streak alive.</p>
      <a href="/student/battleground-prizes" class="inline-flex items-center gap-2 mt-4 px-3 py-2 rounded-lg bg-white/15 hover:bg-white/20 text-white text-xs font-semibold transition">
        View Prize Roadmap
      </a>
    </div>

    <div class="p-6 md:p-8 space-y-6">
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 md:p-6 lift fade-up-1">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500">Current Streak</p>
            <p id="streak-current" class="text-2xl font-bold text-gray-900 mt-1">0</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500">Best Streak</p>
            <p id="streak-best" class="text-2xl font-bold text-gray-900 mt-1">0</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500">Today's Progress</p>
            <p id="streak-progress" class="text-sm font-semibold text-gray-900 mt-2">-</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500">Date</p>
            <p id="streak-date" class="text-sm font-semibold text-gray-900 mt-2">-</p>
          </div>
        </div>
      </section>

      <section id="battleground-loading" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-sm text-gray-500">
        Loading today's battleground...
      </section>

      <section id="battleground-error" class="hidden bg-white rounded-2xl shadow-sm border border-red-100 p-6 text-sm text-red-600"></section>

      <section id="battleground-content" class="hidden space-y-4"></section>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/student/battleground.js"></script>
</body>
</html>
