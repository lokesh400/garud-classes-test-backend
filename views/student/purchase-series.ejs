<%- include('../partials/head', { title: 'Purchase Test Series' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Student Portal</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white">Purchase Test Series</h1>
      <p class="text-white/60 text-sm mt-1">Explore our test series for JEE, NEET and more</p>
    </div>

    <div class="p-6 md:p-8">
    <!-- Filter -->
    <div class="mb-6">
      <select id="category-filter"
              class="px-4 py-2 rounded-lg border border-gray-300 text-gray-700 outline-none">
        <option value="all">All Categories</option>
        <option value="jee">JEE</option>
        <option value="neet">NEET</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div id="loading" class="flex items-center justify-center py-12"><div class="spinner"></div></div>
    <div id="series-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
    </div><!-- /p-6 -->
  </div><!-- /page-body -->

  <!-- Razorpay CDN will be loaded dynamically -->
  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/student/purchase-series.js"></script>
</body>
</html>
