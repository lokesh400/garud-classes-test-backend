<%- include('../partials/head', { title: 'Purchase Test Series' }) %>
<body class="min-h-screen bg-gray-50 text-gray-900">
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 md:pt-0 min-h-screen p-6 max-w-7xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-800 mb-6">Purchase Test Series</h1>

    <!-- Filter -->
    <div class="mb-6">
      <select id="category-filter"
              class="px-4 py-2 rounded-lg border border-gray-300 text-gray-700 outline-none">
        <option value="all">All Categories</option>
        <option value="jee">JEE</option>
        <option value="neet">NEET</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div id="loading" class="flex items-center justify-center py-12"><div class="spinner"></div></div>
    <div id="series-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
  </div>

  <!-- Razorpay CDN will be loaded dynamically -->
  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/purchase-series.js"></script>
</body>
</html>
