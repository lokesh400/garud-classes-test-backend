<%- include('../partials/head', { title: 'Battleground Prizes' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up relative overflow-hidden">
      <div class="absolute -top-12 -right-8 w-44 h-44 rounded-full bg-amber-300/20 blur-2xl pointer-events-none"></div>
      <div class="absolute -bottom-14 left-10 w-52 h-52 rounded-full bg-emerald-300/20 blur-2xl pointer-events-none"></div>

      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Student Portal</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white">Battleground Prize Roadmap</h1>
      <p class="text-white/70 text-sm mt-1">Keep your streak alive to unlock Garud Classes rewards.</p>
      <a href="/student/battleground" class="inline-flex items-center gap-2 mt-4 px-3 py-2 rounded-lg bg-white/15 hover:bg-white/20 text-white text-xs font-semibold transition">
        Back to Battleground
      </a>
    </div>

    <div class="p-6 md:p-8 space-y-6">
      <section class="bg-gradient-to-r from-slate-900 via-slate-800 to-emerald-900 rounded-2xl shadow-sm border border-slate-700 p-5 md:p-6 text-white lift fade-up-1">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
          <div>
            <p class="text-xs uppercase tracking-wide text-white/60">Your Current Streak</p>
            <p id="prize-current-streak" class="text-4xl font-black mt-1">0</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-white/60">Next Prize</p>
            <p id="prize-next-target" class="text-lg font-bold mt-1">-</p>
            <p id="prize-next-hint" class="text-xs text-white/70 mt-1">Loading...</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-white/60">Roadmap Progress</p>
            <div class="mt-2 h-3 rounded-full bg-white/20 overflow-hidden">
              <div id="prize-progress-bar" class="h-full w-0 bg-gradient-to-r from-amber-300 via-orange-400 to-pink-400 transition-all duration-500"></div>
            </div>
            <p id="prize-progress-text" class="text-xs text-white/70 mt-1">0 / 365 days</p>
          </div>
        </div>
      </section>

      <section id="prize-roadmap" class="space-y-3"></section>

      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 md:p-6 lift fade-up-3">
        <h2 class="text-base md:text-lg font-bold text-gray-900">How Rewards Unlock</h2>
        <ul class="mt-3 text-sm text-gray-600 space-y-1.5">
          <li>Streak means qualifying daily battleground submissions without breaking continuity.</li>
          <li>Claim eligibility is checked by Garud Classes admin after streak milestones are reached.</li>
          <li>If a day is missed, streak rules from battleground profile apply.</li>
        </ul>
      </section>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/student/battleground-prizes.js"></script>
</body>
</html>
