<%- include('../partials/head', { title: 'Results' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div id="loading" class="flex items-center justify-center min-h-[60vh]"><div class="spinner"></div></div>
    <div id="main-content" class="hidden">

      <!-- Header -->
      <div class="page-header px-6 md:px-8 py-7 fade-up">
        <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-2">Student Portal</p>
        <div class="flex items-center gap-3">
          <button onclick="window.location.href='/student/dashboard'"
                  class="p-2 text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition">&larr;</button>
          <div>
            <h1 id="test-title" class="text-2xl md:text-3xl font-bold text-white"></h1>
            <p id="submitted-at" class="text-white/60 text-sm mt-0.5"></p>
          </div>
        </div>
      </div>

      <div class="p-6 md:p-8">
      <!-- Score cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8 fade-up-1" id="score-cards"></div>

      <!-- Section breakdown -->
      <div id="sections-review"></div>
      </div><!-- /p-6 -->
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/results.js"></script>
</body>
</html>
