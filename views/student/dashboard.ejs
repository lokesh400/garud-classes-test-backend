<%- include('../partials/head', { title: 'Dashboard' }) %>
<body class="min-h-screen bg-[#fffaf2] text-slate-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap');

    .dash-shell {
      font-family: 'Outfit', sans-serif;
      min-height: calc(100vh - 3.5rem);
      background:
        radial-gradient(circle at 8% 8%, rgba(250, 204, 21, 0.22), transparent 34%),
        radial-gradient(circle at 94% 14%, rgba(34, 197, 94, 0.15), transparent 36%),
        linear-gradient(180deg, #fff8e8 0%, #fffcf5 44%, #ffffff 100%);
    }

    .dash-main {
      min-height: calc(100vh - 3.5rem);
      display: flex;
      flex-direction: column;
    }

    .dash-content {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .dash-title {
      font-family: 'Sora', sans-serif;
      letter-spacing: -0.03em;
    }

    .dash-hero {
      border-radius: 1.6rem;
      background: linear-gradient(132deg, #0f172a 0%, #1e293b 57%, #334155 100%);
      box-shadow: 0 22px 55px rgba(15, 23, 42, 0.24);
      position: relative;
      overflow: hidden;
    }

    .dash-hero::before {
      content: '';
      position: absolute;
      width: 320px;
      height: 320px;
      border-radius: 999px;
      right: -95px;
      top: -170px;
      background: rgba(251, 191, 36, 0.32);
    }

    .dash-hero::after {
      content: '';
      position: absolute;
      width: 260px;
      height: 260px;
      border-radius: 999px;
      left: -90px;
      bottom: -140px;
      background: rgba(34, 211, 238, 0.2);
    }

    .dash-card {
      border: 1px solid #e8eef6;
      background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
      border-radius: 1.2rem;
    }

    .dash-action {
      border: 1px solid #ecf0f7;
      background: #fff;
      border-radius: 1rem;
      transition: transform 0.22s ease, box-shadow 0.24s ease, border-color 0.22s ease;
    }

    .dash-action:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 32px rgba(14, 23, 38, 0.1);
      border-color: #cfd9e6;
    }

    @media (max-width: 768px) {
      .dash-hero {
        border-radius: 1.15rem;
      }
    }
  </style>

  <div class="md:ml-60 pt-14 page-body dash-shell dash-main">
    <div class="max-w-7xl w-full mx-auto px-4 md:px-8 py-6 md:py-8 dash-content">
      <section class="dash-hero p-6 md:p-8 fade-up">
        <div class="relative z-10">
          <p class="text-white/60 text-sm font-semibold uppercase tracking-[0.22em]">Student Command Center</p>
          <h1 id="welcome-title" class="dash-title text-4xl md:text-5xl text-white font-extrabold mt-2">Welcome back!</h1>
          <p class="text-base md:text-lg text-white/75 mt-2 max-w-2xl">Track your momentum, revisit your study material, and jump straight into tests and purchased courses with zero friction.</p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-6 max-w-3xl">
            <div class="rounded-xl border border-white/20 bg-white/10 p-3.5">
              <p class="text-xs uppercase tracking-wide text-white/60">Focus</p>
              <p class="text-white text-base font-semibold mt-1">Daily Practice</p>
            </div>
            <div class="rounded-xl border border-white/20 bg-white/10 p-3.5">
              <p class="text-xs uppercase tracking-wide text-white/60">Mode</p>
              <p class="text-white text-base font-semibold mt-1">Exam Simulation</p>
            </div>
            <div class="rounded-xl border border-white/20 bg-white/10 p-3.5">
              <p class="text-xs uppercase tracking-wide text-white/60">Target</p>
              <p class="text-white text-base font-semibold mt-1">Consistent Improvement</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-3 mt-6">
            <a href="/student/study" class="px-5 py-2.5 bg-orange-500 hover:bg-orange-600 text-white rounded-xl font-semibold text-base transition">Continue Study</a>
            <a href="/student/purchase-series" class="px-5 py-2.5 bg-white/10 text-white border border-white/25 rounded-xl font-semibold text-base hover:bg-white/20 transition">Explore Test Series</a>
          </div>
        </div>
      </section>

      <section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-6 fade-up-1">
        <a href="/student/study" class="dash-action p-4 md:p-5 flex flex-col gap-2.5">
          <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center text-blue-700 text-xl">&#128218;</div>
          <p class="text-base font-semibold text-slate-800">Study Hub</p>
          <p class="text-sm text-slate-500">Access your lectures and revision flow.</p>
        </a>
        <a href="/student/purchase-series" class="dash-action p-4 md:p-5 flex flex-col gap-2.5">
          <div class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-700 text-xl">&#128722;</div>
          <p class="text-base font-semibold text-slate-800">Buy Series</p>
          <p class="text-sm text-slate-500">Unlock new tests and challenges.</p>
        </a>
        <a href="/student/tests" class="dash-action p-4 md:p-5 flex flex-col gap-2.5">
          <div class="w-11 h-11 rounded-xl bg-violet-50 flex items-center justify-center text-violet-700 text-xl">&#128221;</div>
          <p class="text-base font-semibold text-slate-800">My Tests</p>
          <p class="text-sm text-slate-500">Attempt and review your test history.</p>
        </a>
        <a href="/student/purchases" class="dash-action p-4 md:p-5 flex flex-col gap-2.5">
          <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center text-amber-700 text-xl">&#128179;</div>
          <p class="text-base font-semibold text-slate-800">Purchases</p>
          <p class="text-sm text-slate-500">Track all your course and series orders.</p>
        </a>
      </section>

      <section class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.2fr),minmax(0,0.8fr)] gap-4 mt-6 fade-up-2 xl:flex-1">
        <article class="dash-card p-5 md:p-6 h-full">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500 font-semibold">Today's Focus</p>
          <h2 class="dash-title text-2xl md:text-3xl text-slate-900 mt-2">Build Momentum In 3 Steps</h2>
          <div class="mt-4 space-y-3">
            <div class="rounded-xl border border-slate-200 bg-white p-3.5 flex items-center justify-between gap-3">
              <div>
                <p class="text-base font-semibold text-slate-800">Revise concepts</p>
                <p class="text-sm text-slate-500 mt-0.5">Open your study area and complete one chapter recap.</p>
              </div>
              <a href="/student/study" class="text-sm font-semibold text-blue-700">Start</a>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-3.5 flex items-center justify-between gap-3">
              <div>
                <p class="text-base font-semibold text-slate-800">Attempt tests</p>
                <p class="text-sm text-slate-500 mt-0.5">Take a timed test and benchmark your speed.</p>
              </div>
              <a href="/student/tests" class="text-sm font-semibold text-blue-700">Attempt</a>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-3.5 flex items-center justify-between gap-3">
              <div>
                <p class="text-base font-semibold text-slate-800">Expand resources</p>
                <p class="text-sm text-slate-500 mt-0.5">Add new series to keep your preparation fresh.</p>
              </div>
              <a href="/student/purchase-series" class="text-sm font-semibold text-blue-700">Explore</a>
            </div>
          </div>
        </article>

        <article class="dash-card p-5 md:p-6 h-full">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500 font-semibold">Quick Toolkit</p>
          <h3 class="dash-title text-xl text-slate-900 mt-2">Everything In One Place</h3>
          <div class="mt-4 grid grid-cols-2 gap-2.5">
            <a href="/student/study" class="rounded-xl border border-slate-200 bg-white py-2.5 px-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Lecture Player</a>
            <a href="/student/tests" class="rounded-xl border border-slate-200 bg-white py-2.5 px-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Mock Tests</a>
            <a href="/student/purchase-history" class="rounded-xl border border-slate-200 bg-white py-2.5 px-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Order History</a>
            <a href="/student/purchase-courses" class="rounded-xl border border-slate-200 bg-white py-2.5 px-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Purchase Courses</a>
          </div>
        </article>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      requireAuth('student');
      const user = getUser();
      if (user) {
        const el = document.getElementById('welcome-title');
        if (el) el.textContent = 'Welcome back, ' + user.name.split(' ')[0] + '!';
      }
    });
  </script>
</body>
</html>
