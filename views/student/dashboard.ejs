<%- include('../partials/head', { title: 'Dashboard' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <!-- Welcome Hero -->
    <div class="page-header px-6 md:px-10 py-10 md:py-14 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-2">Student Portal</p>
      <h1 id="welcome-title" class="text-3xl md:text-4xl font-extrabold text-white leading-tight">Welcome back!</h1>
      <p class="text-white/60 text-sm mt-2 max-w-md">Continue your preparation journey. Your tests and series are waiting.</p>
      <div class="flex flex-wrap gap-3 mt-6">
        <a href="/student/purchase-series" class="px-5 py-2.5 bg-garud-highlight text-white rounded-xl font-semibold text-sm hover:opacity-90 transition shadow-lg">
          Browse Series
        </a>
        <a href="/student/study" class="px-5 py-2.5 bg-white/10 text-white border border-white/20 rounded-xl font-semibold text-sm hover:bg-white/20 transition">
          My Study
        </a>
      </div>
    </div>

    <!-- Quick links -->
    <div class="p-6 md:p-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 fade-up-1">
        <a href="/student/study" class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-5 flex flex-col items-center gap-2 text-center group">
          <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center group-hover:bg-blue-100 transition">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <span class="text-sm font-semibold text-gray-700">Study</span>
        </a>
        <a href="/student/purchase-series" class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-5 flex flex-col items-center gap-2 text-center group">
          <div class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center group-hover:bg-emerald-100 transition">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          </div>
          <span class="text-sm font-semibold text-gray-700">Buy Series</span>
        </a>
        <a href="/student/tests" class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-5 flex flex-col items-center gap-2 text-center group">
          <div class="w-11 h-11 rounded-xl bg-violet-50 flex items-center justify-center group-hover:bg-violet-100 transition">
            <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <span class="text-sm font-semibold text-gray-700">My Tests</span>
        </a>
        <a href="/student/purchases" class="bg-white rounded-2xl shadow-sm border border-gray-100 lift p-5 flex flex-col items-center gap-2 text-center group">
          <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center group-hover:bg-amber-100 transition">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          </div>
          <span class="text-sm font-semibold text-gray-700">Purchases</span>
        </a>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      requireAuth('student');
      const user = getUser();
      if (user) {
        const el = document.getElementById('welcome-title');
        if (el) el.textContent = 'Welcome back, ' + user.name.split(' ')[0] + '!';
      }
    });
  </script>
</body>
</html>
