<%- include('./partials/head', { title: 'Register' }) %>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-primary-100 to-primary-300">

  <div class="max-w-md w-full mx-4">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-primary-600">GARUD</h1>
      <p class="text-gray-500 mt-1">Classes Test Portal</p>
    </div>

    <div class="bg-white rounded-xl shadow-2xl p-8">

      <!-- Step indicator -->
      <div class="flex items-center justify-center gap-2 mb-6 text-sm font-semibold" id="step-indicator">
        <span id="step1-label" class="text-primary-600">Step 1</span>
        <span class="text-gray-300">›</span>
        <span id="step2-label" class="text-gray-400">Step 2</span>
        <span class="text-gray-300">›</span>
        <span id="step3-label" class="text-gray-400">Review ✓</span>
      </div>

      <form id="register-form" novalidate class="space-y-4">

        <!-- Step 1 -->
        <div id="step-1">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
            <input id="name" type="text" placeholder="Your full name"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 outline-none transition"/>
          </div>
          <div class="mt-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">Class</label>
            <select id="studentClass"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 outline-none transition">
              <option value="">Select Class</option>
              <option>9</option><option>10</option><option>11</option><option>12</option><option>Dropper</option>
            </select>
          </div>
          <div class="mt-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">Target Exam</label>
            <select id="targetExam"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 outline-none transition">
              <option value="">Select Exam</option>
              <option>JEE</option><option>NEET</option><option>FOUNDATION</option><option>CUET</option><option>NDA</option>
            </select>
          </div>
          <div class="flex justify-end mt-6">
            <button type="button" id="next-1"
                    class="px-6 py-2 bg-primary-500 text-white rounded-lg font-semibold hover:bg-primary-600 transition">
              Next →
            </button>
          </div>
        </div>

        <!-- Step 2 -->
        <div id="step-2" class="hidden">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Mobile Number</label>
            <input id="mobile" type="tel" placeholder="10-digit mobile number"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 outline-none transition"/>
          </div>
          <div class="mt-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input id="email" type="email" placeholder="your@email.com"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 outline-none transition"/>
          </div>
          <div class="mt-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input id="password" type="password" placeholder="Choose a password"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 outline-none transition"/>
          </div>
          <div class="flex justify-between mt-6">
            <button type="button" id="prev-2"
                    class="px-6 py-2 border border-gray-300 text-gray-600 rounded-lg font-semibold hover:bg-gray-50 transition">
              ← Back
            </button>
            <button type="button" id="next-2"
                    class="px-6 py-2 bg-primary-500 text-white rounded-lg font-semibold hover:bg-primary-600 transition">
              Next →
            </button>
          </div>
        </div>

        <!-- Step 3 — Review -->
        <div id="step-3" class="hidden">
          <h3 class="font-semibold text-gray-700 mb-3">Review your details</h3>
          <div class="space-y-2 text-sm text-gray-600 bg-gray-50 rounded-lg p-4" id="review-box"></div>
          <div class="flex justify-between mt-6">
            <button type="button" id="prev-3"
                    class="px-6 py-2 border border-gray-300 text-gray-600 rounded-lg font-semibold hover:bg-gray-50 transition">
              ← Back
            </button>
            <button type="submit" id="submit-btn"
                    class="px-6 py-2 bg-primary-500 text-white rounded-lg font-semibold hover:bg-primary-600 transition disabled:opacity-50">
              Register
            </button>
          </div>
        </div>

      </form>

      <p class="mt-4 text-center text-sm text-gray-600">
        Already have an account?
        <a href="/login" class="text-primary-600 font-semibold hover:underline">Sign in</a>
      </p>
    </div>
  </div>

  <%- include('./partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/pages/register.js"></script>
</body>
</html>
