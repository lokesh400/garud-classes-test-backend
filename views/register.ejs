<%- include('./partials/head', { title: 'Register' }) %>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-garud-dark via-garud-mid to-garud-accent relative overflow-hidden py-8">

  <!-- Decorative blobs -->
  <div class="absolute top-[-80px] right-[-60px] w-72 h-72 bg-garud-highlight/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-[-60px] left-[-80px] w-64 h-64 bg-garud-accent/20 rounded-full blur-3xl"></div>

  <div class="max-w-md w-full mx-4 relative z-10 fade-up">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-garud-highlight/20 border border-garud-highlight/30 mb-4">
        <span class="text-2xl font-black text-garud-highlight">G</span>
      </div>
      <h1 class="text-3xl font-black text-white tracking-tight">GARUD <span class="text-garud-highlight">Classes</span></h1>
      <p class="text-white/50 text-sm mt-1">Create your account</p>
    </div>

    <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl shadow-2xl p-8">

      <!-- Step indicator -->
      <div class="flex items-center justify-center gap-2 mb-6 text-sm font-semibold" id="step-indicator">
        <span id="step1-label" class="text-garud-highlight">Step 1</span>
        <span class="text-white/20">›</span>
        <span id="step2-label" class="text-white/40">Step 2</span>
        <span class="text-white/20">›</span>
        <span id="step3-label" class="text-white/40">Review ✓</span>
      </div>

      <form id="register-form" novalidate class="space-y-4">

        <!-- Step 1 -->
        <div id="step-1">
          <div>
            <label class="block text-xs font-semibold text-white/60 uppercase tracking-widest mb-1.5">Full Name</label>
            <input id="name" type="text" placeholder="Your full name"
                   class="w-full px-4 py-3 bg-white/10 border border-white/15 text-white placeholder-white/30 rounded-xl focus:ring-2 focus:ring-garud-highlight outline-none transition"/>
          </div>
          <div class="mt-4">
            <label class="block text-xs font-semibold text-white/60 uppercase tracking-widest mb-1.5">Class</label>
            <select id="studentClass"
                    class="w-full px-4 py-3 bg-white/10 border border-white/15 text-white rounded-xl focus:ring-2 focus:ring-garud-highlight outline-none transition">
              <option value="" class="text-gray-800">Select Class</option>
              <option class="text-gray-800">9</option><option class="text-gray-800">10</option><option class="text-gray-800">11</option><option class="text-gray-800">12</option><option class="text-gray-800">Dropper</option>
            </select>
          </div>
          <div class="mt-4">
            <label class="block text-xs font-semibold text-white/60 uppercase tracking-widest mb-1.5">Target Exam</label>
            <select id="targetExam"
                    class="w-full px-4 py-3 bg-white/10 border border-white/15 text-white rounded-xl focus:ring-2 focus:ring-garud-highlight outline-none transition">
              <option value="" class="text-gray-800">Select Exam</option>
              <option class="text-gray-800">JEE</option><option class="text-gray-800">NEET</option><option class="text-gray-800">FOUNDATION</option><option class="text-gray-800">CUET</option><option class="text-gray-800">NDA</option>
            </select>
          </div>
          <div class="flex justify-end mt-6">
            <button type="button" id="next-1"
                    class="px-6 py-3 bg-garud-highlight text-white rounded-xl font-bold hover:opacity-90 transition">
              Next →
            </button>
          </div>
        </div>

        <!-- Step 2 -->
        <div id="step-2" class="hidden">
          <div>
            <label class="block text-xs font-semibold text-white/60 uppercase tracking-widest mb-1.5">Mobile Number</label>
            <input id="mobile" type="tel" placeholder="10-digit mobile number"
                   class="w-full px-4 py-3 bg-white/10 border border-white/15 text-white placeholder-white/30 rounded-xl focus:ring-2 focus:ring-garud-highlight outline-none transition"/>
          </div>
          <div class="mt-4">
            <label class="block text-xs font-semibold text-white/60 uppercase tracking-widest mb-1.5">Email</label>
            <input id="email" type="email" placeholder="your@email.com"
                   class="w-full px-4 py-3 bg-white/10 border border-white/15 text-white placeholder-white/30 rounded-xl focus:ring-2 focus:ring-garud-highlight outline-none transition"/>
          </div>
          <div class="mt-4">
            <label class="block text-xs font-semibold text-white/60 uppercase tracking-widest mb-1.5">Password</label>
            <input id="password" type="password" placeholder="Choose a password"
                   class="w-full px-4 py-3 bg-white/10 border border-white/15 text-white placeholder-white/30 rounded-xl focus:ring-2 focus:ring-garud-highlight outline-none transition"/>
          </div>
          <div class="flex justify-between mt-6">
            <button type="button" id="prev-2"
                    class="px-6 py-3 border border-white/20 text-white/70 rounded-xl font-semibold hover:bg-white/10 transition">
              ← Back
            </button>
            <button type="button" id="next-2"
                    class="px-6 py-3 bg-garud-highlight text-white rounded-xl font-bold hover:opacity-90 transition">
              Next →
            </button>
          </div>
        </div>

        <!-- Step 3 — Review -->
        <div id="step-3" class="hidden">
          <h3 class="font-semibold text-white/80 mb-3">Review your details</h3>
          <div class="space-y-2 text-sm text-white/70 bg-white/10 border border-white/10 rounded-xl p-4" id="review-box"></div>
          <div class="flex justify-between mt-6">
            <button type="button" id="prev-3"
                    class="px-6 py-3 border border-white/20 text-white/70 rounded-xl font-semibold hover:bg-white/10 transition">
              ← Back
            </button>
            <button type="submit" id="submit-btn"
                    class="px-6 py-3 bg-garud-highlight text-white rounded-xl font-bold hover:opacity-90 transition disabled:opacity-50">
              Register
            </button>
          </div>
        </div>

      </form>

      <p class="mt-5 text-center text-sm text-white/50">
        Already have an account?
        <a href="/login" class="text-garud-highlight font-semibold hover:underline">Sign in</a>
      </p>

      <div class="mt-6 pt-5 border-t border-white/10 flex flex-col sm:flex-row items-center justify-center gap-3 text-xs text-white/30">
        <a href="tel:9896913009" class="flex items-center gap-1.5 hover:text-white/60 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          9896913009
        </a>
        <span class="hidden sm:block text-white/20">&bull;</span>
        <a href="mailto:info@garudclasses.com" class="flex items-center gap-1.5 hover:text-white/60 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          info@garudclasses.com
        </a>
      </div>
    </div>
  </div>

  <%- include('./partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/pages/register.js"></script>
</body>
</html>
