<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <%
    const _pageTitle  = typeof title !== 'undefined' ? title + ' — GARUD Classes Test Portal' : 'GARUD Classes Test Portal';
    const _siteUrl    = 'https://testportal.garudclasses.com';
    const _siteName   = 'GARUD Classes Test Portal';
    const _desc       = 'GARUD Classes Test Portal — Practice mock tests, chapter-wise quizzes and full-length exams for competitive exam preparation. Trusted by students preparing for JEE, NEET, and government exams.';
    const _keywords   = 'GARUD Classes, garudclasses, Garud Classes, test portal, mock test, online test series, JEE mock test, NEET mock test, competitive exam, chapter wise test, question bank, garud classes test';
    const _logo       = _siteUrl + '/images/logo.png';
  %>

  <title><%= _pageTitle %></title>

  <!-- ── Canonical & indexing ──────────────────────────────────── -->
  <link rel="canonical" href="<%= typeof pageUrl !== 'undefined' ? pageUrl : _siteUrl %>"/>
  <meta name="robots"    content="index, follow"/>
  <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"/>
  <meta name="bingbot"   content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"/>
  <meta name="msvalidate.01" content="9D75CB9B8C8587CA6B378AC8E10FD2AC" />

  <!-- ── Primary SEO meta ──────────────────────────────────────── -->
  <meta name="description" content="<%= _desc %>"/>
  <meta name="keywords"    content="<%= _keywords %>"/>
  <meta name="author"      content="GARUD Classes"/>
  <meta name="theme-color" content="#0f3460"/>

  <!-- ── Open Graph (Facebook / WhatsApp / LinkedIn) ───────────── -->
  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content="<%= _siteUrl %>"/>
  <meta property="og:site_name"   content="<%= _siteName %>"/>
  <meta property="og:title"       content="<%= _pageTitle %>"/>
  <meta property="og:description" content="<%= _desc %>"/>
  <meta property="og:image"       content="<%= _logo %>"/>
  <meta property="og:image:width" content="512"/>
  <meta property="og:image:height" content="512"/>
  <meta property="og:locale"      content="en_IN"/>

  <!-- ── Twitter Card ─────────────────────────────────────────── -->
  <meta name="twitter:card"        content="summary"/>
  <meta name="twitter:site"        content="@garudclasses"/>
  <meta name="twitter:title"       content="<%= _pageTitle %>"/>
  <meta name="twitter:description" content="<%= _desc %>"/>
  <meta name="twitter:image"       content="<%= _logo %>"/>

  <!-- ── Favicon ──────────────────────────────────────────────── -->
  <link rel="icon"             type="image/png" sizes="32x32"  href="/images/logo.png"/>
  <link rel="icon"             type="image/png" sizes="16x16"  href="/images/logo.png"/>
  <link rel="apple-touch-icon"                  sizes="180x180" href="/images/logo.png"/>
  <link rel="shortcut icon"    type="image/png"                 href="/images/logo.png"/>
  <link rel="manifest" href="/site.webmanifest"/>

  <!-- ── Structured data (JSON-LD) ────────────────────────────── -->
  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "GARUD Classes",
      "url": "<%= _siteUrl %>",
      "logo": {
        "@type": "ImageObject",
        "url": "<%= _logo %>"
      },
      "description": "<%= _desc %>",
      "sameAs": ["https://garudclasses.com"]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "<%= _siteName %>",
      "url": "<%= _siteUrl %>",
      "description": "<%= _desc %>",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "<%= _siteUrl %>/student/test-series?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  ]
  </script>
  <!-- Tailwind CDN Play CDN (supports config customisation) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: {
              50:  '#eff6ff',
              100: '#dbeafe',
              200: '#bfdbfe',
              300: '#93c5fd',
              400: '#60a5fa',
              500: '#3b82f6',
              600: '#2563eb',
              700: '#1d4ed8',
              800: '#1e40af',
              900: '#1e3a8a',
            },
            garud: {
              dark:      '#1a1a2e',
              mid:       '#16213e',
              accent:    '#0f3460',
              highlight: '#e94560',
            },
          },
        },
      },
    };
  </script>
  <style type="text/tailwindcss">
    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #f1f1f1; }
    ::-webkit-scrollbar-thumb { background: #888; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #555; }

    /* Spinner utility */
    .spinner {
      border: 3px solid #e5e7eb;
      border-top-color: #e94560;
      border-radius: 50%;
      width: 2.5rem;
      height: 2.5rem;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Toast */
    #toast-container {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .toast {
      min-width: 220px;
      padding: 0.75rem 1.25rem;
      border-radius: 0.625rem;
      background: #333;
      color: #fff;
      font-size: 0.875rem;
      box-shadow: 0 4px 12px rgba(0,0,0,.25);
      animation: slideIn 0.25s ease;
    }
    .toast.success { background: #16a34a; }
    .toast.error   { background: #dc2626; }
    @keyframes slideIn {
      from { transform: translateX(110%); opacity: 0; }
      to   { transform: translateX(0);   opacity: 1; }
    }

    /* ── Page & card animations ────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    .page-body      { animation: fadeIn 0.3s ease-out both; }
    .fade-up        { animation: fadeUp 0.4s ease-out both; }
    .fade-up-1      { animation: fadeUp 0.4s ease-out 0.07s both; }
    .fade-up-2      { animation: fadeUp 0.4s ease-out 0.14s both; }
    .fade-up-3      { animation: fadeUp 0.4s ease-out 0.21s both; }

    /* ── Lift cards on hover ───────────────────────────────── */
    .lift { transition: box-shadow 0.25s ease, transform 0.22s ease; }
    .lift:hover {
      box-shadow: 0 14px 40px rgba(15,52,96,0.14) !important;
      transform: translateY(-3px);
    }

    /* ── Gradient page header strip ─────────────────────────── */
    .page-header {
      background: linear-gradient(135deg, #0f3460 0%, #16213e 60%, #1a1a2e 100%);
      position: relative; overflow: hidden;
    }
    .page-header::before {
      content: ''; position: absolute; top: -50%; right: -5%;
      width: 260px; height: 260px;
      background: rgba(233,69,96,0.09); border-radius: 50%;
    }
    .page-header::after {
      content: ''; position: absolute; bottom: -40%; right: 18%;
      width: 130px; height: 130px;
      background: rgba(233,69,96,0.05); border-radius: 50%;
    }

    /* ── Improved scrollbar ────────────────────────────────── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: #f1f5f9; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #0f3460; }

    /* ── Stat card gradient accents ───────────────────────── */
    .stat-card { position: relative; overflow: hidden; }
    .stat-card::before {
      content: ''; position: absolute; top: 0; left: 0;
      width: 4px; height: 100%; border-radius: 4px 0 0 4px;
    }
    .stat-blue::before  { background: #3b82f6; }
    .stat-green::before { background: #10b981; }
    .stat-red::before   { background: #e94560; }
    .stat-amber::before { background: #f59e0b; }

    /* ── Focus ring polish ─────────────────────────────────── */
    input:focus, select:focus, textarea:focus {
      outline: none;
      box-shadow: 0 0 0 3px rgba(15,52,96,0.12);
    }
    button { transition: opacity 0.18s, background 0.18s, transform 0.15s, box-shadow 0.18s; }
    button:active { transform: scale(0.97); }
  </style>
</head>
