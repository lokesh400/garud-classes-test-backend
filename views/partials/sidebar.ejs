<!-- Sidebar — hidden by default, shown by sidebar.js after auth check -->
<div id="sidebar-overlay"
     class="fixed inset-0 bg-black/50 z-30 md:hidden hidden"
     onclick="closeSidebar()"></div>

<!-- Desktop sidebar -->
<aside id="sidebar"
       class="fixed top-0 left-0 h-full w-60 z-40 flex flex-col
              bg-gradient-to-b from-garud-dark via-garud-mid to-garud-dark
              border-r border-white/5
              transform -translate-x-full md:translate-x-0 transition-transform duration-200">

  <!-- Brand -->
  <div class="flex items-center justify-between px-5 py-5 border-b border-white/10">
    <a href="/" class="flex items-center gap-2.5">
      <div class="w-8 h-8 rounded-xl bg-garud-highlight flex items-center justify-center flex-shrink-0">
        <span class="text-white font-black text-sm">G</span>
      </div>
      <span class="text-base font-extrabold text-white tracking-wide">GARUD <span class="text-garud-highlight">Classes</span></span>
    </a>
    <button onclick="closeSidebar()"
            class="md:hidden text-white/40 hover:text-white transition">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Nav links (populated by sidebar.js) -->
  <nav id="sidebar-nav" class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto"></nav>

  <!-- User info & logout -->
  <div class="border-t border-white/10 px-4 py-4 space-y-3">
    <div class="flex items-center gap-3">
      <div id="user-avatar"
           class="w-9 h-9 rounded-xl bg-garud-highlight flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
        ?
      </div>
      <div class="flex-1 min-w-0">
        <p id="user-name"  class="text-sm font-semibold text-white truncate">Loading…</p>
        <p id="user-role"  class="text-xs text-white/40 capitalize"></p>
      </div>
    </div>
    <button onclick="handleLogout()"
            class="flex items-center gap-2 w-full px-3 py-2.5 text-sm font-medium text-white/50
                   hover:bg-white/10 hover:text-white rounded-xl transition">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1"/>
      </svg>
      Sign Out
    </button>
    <!-- Contact info -->
    <div class="pt-2 border-t border-white/5 space-y-1">
      <a href="tel:9896913009" class="flex items-center gap-2 text-xs text-white/25 hover:text-white/50 transition px-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        9896913009
      </a>
      <a href="mailto:info@garudclasses.com" class="flex items-center gap-2 text-xs text-white/25 hover:text-white/50 transition px-1 truncate">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        info@garudclasses.com
      </a>
    </div>
  </div>
</aside>

