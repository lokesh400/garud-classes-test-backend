<!-- Sidebar — hidden by default, shown by sidebar.js after auth check -->
<div id="sidebar-overlay"
     class="fixed inset-0 bg-black/40 z-30 md:hidden hidden"
     onclick="closeSidebar()"></div>

<!-- Desktop sidebar -->
<aside id="sidebar"
       class="fixed top-0 left-0 h-full w-60 bg-white border-r border-gray-200 z-40 flex flex-col
              transform -translate-x-full md:translate-x-0 transition-transform duration-200">

  <!-- Brand -->
  <div class="flex items-center justify-between px-5 py-5 border-b border-gray-200">
    <a href="/" class="flex items-center gap-2">
      <span class="text-2xl font-extrabold text-garud-highlight tracking-wide">GARUD</span>
      <span class="text-xs text-gray-400 mt-1">Classes</span>
    </a>
    <button onclick="closeSidebar()"
            class="md:hidden text-gray-400 hover:text-garud-highlight">
      <!-- X icon -->
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Nav links (populated by sidebar.js) -->
  <nav id="sidebar-nav" class="flex-1 px-3 py-4 space-y-1 overflow-y-auto"></nav>

  <!-- User info & logout -->
  <div class="border-t border-gray-200 px-4 py-4 space-y-3">
    <div class="flex items-center gap-3">
      <div id="user-avatar"
           class="w-9 h-9 rounded-full bg-garud-accent flex items-center justify-center text-white font-bold text-sm">
        ?
      </div>
      <div class="flex-1 min-w-0">
        <p id="user-name"  class="text-sm font-medium text-gray-900 truncate">Loading…</p>
        <p id="user-role"  class="text-xs text-gray-500 capitalize"></p>
      </div>
    </div>
    <button onclick="handleLogout()"
            class="flex items-center gap-2 w-full px-3 py-2.5 text-sm font-medium text-red-500
                   hover:bg-red-50 rounded-lg transition">
      <!-- Logout icon -->
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1"/>
      </svg>
      Logout
    </button>
  </div>
</aside>

<!-- Mobile top bar (hamburger) — shown only when not in full-screen test -->
<div id="mobile-bar"
     class="md:hidden fixed top-0 left-0 right-0 z-30 bg-white border-b border-gray-200
            flex items-center gap-3 px-4 py-3">
  <button onclick="openSidebar()" class="text-gray-600 hover:text-garud-highlight">
    <!-- Hamburger icon -->
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>
  <span class="font-bold text-garud-highlight text-lg">GARUD</span>
</div>
